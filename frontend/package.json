{
  "name": "enersok-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build && next-sitemap",
    "start": "next start",
    "dev": "next dev --turbopack",
    "clean": "rm -rf .next dist node_modules",
    "lint": "npx @biomejs/biome lint ./src",
    "lint:fix": "npx @biomejs/biome lint --write ./src",
    "fmt": "npx @biomejs/biome format ./src",
    "fmt:fix": "npx @biomejs/biome format --write ./src",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "serve": "next start -p 3001"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npx @biomejs/biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@plaiceholder/next": "^3.0.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.3",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@tanstack/react-query": "^5.64.2",
    "@uidotdev/usehooks": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "dayjs": "^1.11.13",
    "embla-carousel-react": "^8.5.2",
    "formidable": "^3.5.2",
    "lucide-react": "^0.453.0",
    "markdown-to-jsx": "^7.7.3",
    "next": "15.0.4",
    "next-intl": "3.26.0",
    "next-sitemap": "^4.2.3",
    "nodemailer": "^6.9.16",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-headless-pagination": "^1.1.6",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@tailwindcss/typography": "^0.5.16",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/formidable": "^3.4.5",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "husky": "^9.1.7",
    "postcss": "^8.5.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}

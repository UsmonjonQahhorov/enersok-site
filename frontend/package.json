{
  "name": "enersok-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build && next-sitemap",
    "start": "next start",
    "dev": "next dev --turbopack",
    "clean": "rm -rf .next dist node_modules",
    "lint": "npx @biomejs/biome lint ./src",
    "lint:fix": "npx @biomejs/biome lint --write ./src",
    "fmt": "npx @biomejs/biome format ./src",
    "fmt:fix": "npx @biomejs/biome format --write ./src",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "serve": "next start -p 3001"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npx @biomejs/biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@plaiceholder/next": "^3.0.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-navigation-menu": "^1.2.1",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@tanstack/react-query": "^5.62.3",
    "@uidotdev/usehooks": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "dayjs": "^1.11.13",
    "embla-carousel-react": "^8.5.1",
    "formidable": "^3.5.2",
    "lucide-react": "^0.453.0",
    "markdown-to-jsx": "^7.7.1",
    "next": "15.0.4",
    "next-intl": "3.26.0",
    "next-sitemap": "^4.2.3",
    "nodemailer": "^6.9.16",
    "plaiceholder": "^3.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-headless-pagination": "^1.1.6",
    "react-hook-form": "^7.53.2",
    "recharts": "^2.14.1",
    "server-only": "^0.0.1",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@tailwindcss/typography": "^0.5.15",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/formidable": "^3.4.5",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "husky": "^9.1.7",
    "postcss": "^8.4.49",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}

      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "type": "string",
      "required": true,
      "default": "The main project facilities will include:"
    },
    "info_section_first_text": {
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "type": "text",
      "required": true,
      "default": "Power block and stacks including two Gas Turbines (GT), two Heat Recovery Steam Generators (HRSG) and one Steam Turbine (ST)"
    },
    "info_section_second_text": {
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "type": "text",
      "required": true,
      "default": "Closed Loop Cooling Water system, with mechanical draft air cooling tower blocks"
    },
    "info_section_third_text": {
      "pluginOptions": {
